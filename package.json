{
  "name": "acs-admin-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:fido": "vite --mode fido",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:emv": "vite build --mode emv",
    "build:emvdemo": "vite build --mode emvdemo",
    "build:jmeter": "vite build --mode jmeter",
    "build:docker": "vite build --mode docker",
    "build:fido": "vite build --mode fido",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prettier:check": "(prettier --check \"src/**/*.{js,vue,css,scss,json}\" || (echo 'Prettier formatting issues detected!' && exit 1))"
  },
  "dependencies": {
    "@coreui/chartjs": "^4.2.0",
    "@coreui/coreui": "^5.5.0",
    "@coreui/icons": "^3.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/poppins": "^5.2.7",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@vuepic/vue-datepicker": "^12.1.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "dompurify": "^3.3.1",
    "jquery": "^4.0.0",
    "luxon": "^3.7.2",
    "msw": "^2.12.10",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qrcode.vue": "^3.8.0",
    "remixicon": "^4.9.1",
    "sha1": "^1.1.1",
    "sha256": "^0.2.0",
    "simplebar-vue": "^2.4.2",
    "sweetalert2": "^11.26.20",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "vue3-cookies": "^1.0.6",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^28.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.0",
    "@types/sha1": "^1.1.5",
    "@types/sha256": "^0.2.2",
    "@types/zxcvbn": "^4.4.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "cypress": "^15.10.0",
    "eslint": "^10.0.2",
    "eslint-plugin-cypress": "^6.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "start-server-and-test": "^2.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.12"
  },
  "overrides": {
    "qs": "^6.14.1",
    "esbuild": "^0.25.0",
    "minimatch": "^10.2.2",
    "glob": "^11.0.0"
  }
}
